{
  "name": "custos",
  "version": "2.0.0",
  "description": "Nia Fiber ERP Automation Bot",
  "license": "ISC",
  "author": "Aster IX",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/core/server.ts",
    "build": "esbuild src/core/server.ts --bundle --platform=node --external:playwright --target=node18 --minify --outfile=dist/server.js && copy .env dist\\.env",
    "start": "node dist/server.js",
    "clean": "if exist dist rmdir /s /q dist",
    "rebuild": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "playwright": "^1.60.0",
    "zod": "^4.4.3"
  }
}
